# laneta-pipeline-api — env vars
# Copy to .env and fill in real values for local dev.
# In Railway, set these in the project's Variables tab.

# Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET=

# Supabase (proyecto tracker: nvbanvwibmghxroybjxp)
SUPABASE_URL=https://nvbanvwibmghxroybjxp.supabase.co
SUPABASE_SERVICE_KEY=

# MillionVerifier (obligatorio para validate_email_mv)
MILLIONVERIFIER_API_KEY=

# Smartlead (obligatorio para smartlead_dedup_check + push)
SMARTLEAD_API_KEY=
SMARTLEAD_META_CAMPAIGNS=3212141,3217790,3213557,3213796,3224154,3224156

# Clay (opcional — pipeline puede saltarlo con PIPELINE_SKIP_CLAY=true)
